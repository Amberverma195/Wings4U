generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext, pgcrypto, uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

model Location {
  id                       String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                     String                    @unique
  name                     String
  addressLine1             String                    @map("address_line_1")
  addressLine2             String?                   @map("address_line_2")
  city                     String
  provinceCode             String                    @map("province_code")
  postalCode               String                    @map("postal_code")
  phoneNumber              String                    @map("phone_number")
  timezoneName             String                    @map("timezone_name")
  isActive                 Boolean                   @default(true) @map("is_active")
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  adminAuditLogs           AdminAuditLog[]
  adminLocationAssignments AdminLocationAssignment[]
  authSessions             AuthSession[]
  busyModeEvents           BusyModeEvent[]
  cancellationRequests     CancellationRequest[]
  cateringInquiries        CateringInquiry[]
  checkoutIdempotencyKeys  CheckoutIdempotencyKey[]
  dailyTaxSummaries        DailyTaxSummary[]
  devices                  Device[]
  kdsHeartbeats            KdsHeartbeat[]
  kdsStationSessions       KdsStationSession[]
  driverPayouts            DriverPayout[]
  driverProfiles           DriverProfile[]
  employeeProfiles         EmployeeProfile[]
  employeeShifts           EmployeeShift[]
  inventoryAdjustments     InventoryAdjustment[]
  inventoryItems           InventoryItem[]
  hours                    LocationHours[]
  settings                 LocationSettings?
  menuCategories           MenuCategory[]
  menuItems                MenuItem[]
  modifierGroups           ModifierGroup[]
  orderDriverEvents        OrderDriverEvent[]
  orderPayments            OrderPayment[]
  orderStatusEvents        OrderStatusEvent[]
  orders                   Order[]
  promoCodes               PromoCode[]
  posLoginAttempts         PosLoginAttempt[]
  posStationSessions       PosStationSession[]
  refundRequests           RefundRequest[]
  registerSessions         RegisterSession[]
  registers                Register[]
  restockLists             RestockList[]
  savedCarts               SavedCart[]
  supportTickets           SupportTicket[]
  wingFlavours             WingFlavour[]

  @@index([isActive], map: "idx_locations_active")
  @@map("locations")
}

model User {
  id                        String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role                      UserRole
  displayName               String                    @map("display_name")
  firstName                 String?                   @map("first_name")
  lastName                  String?                   @map("last_name")
  passwordHash              String?                   @map("password_hash")
  isActive                  Boolean                   @default(true) @map("is_active")
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt                DateTime?                 @map("archived_at") @db.Timestamptz(6)
  adminAuditLogs            AdminAuditLog[]
  adminLocationAssignments  AdminLocationAssignment[]
  authSessionsRevokedBy     AuthSession[]             @relation("session_revoked_by")
  authSessions              AuthSession[]
  busyModeEventsStarted     BusyModeEvent[]           @relation("busy_event_started_by")
  busyModeEventsEnded       BusyModeEvent[]           @relation("busy_event_ended_by")
  cancellationRequestsBy    CancellationRequest[]     @relation("cancel_requested_by")
  cancellationReviewedBy    CancellationRequest[]     @relation("cancel_reviewed_by")
  cashDrawerEvents          CashDrawerEvent[]         @relation("drawer_actor")
  cashDrawerApprovedBy      CashDrawerEvent[]         @relation("drawer_approved_by")
  cateringInquiries         CateringInquiry[]
  chatReadStates            ChatReadState[]
  checkoutIdempotencyKeys   CheckoutIdempotencyKey[]
  creditCreatedBy           CustomerCreditLedger[]    @relation("credit_created_by")
  customerCreditLedger      CustomerCreditLedger[]    @relation("credit_customer")
  customerAddresses         CustomerAddress[]
  customerProfile           CustomerProfile?
  customerWallet            CustomerWallet?
  customerWingsRewards      CustomerWingsRewards?
  customerWingsStampLedger  CustomerWingsStampLedger[]
  deliveryPinBypassBy       DeliveryPinVerification[] @relation("pin_bypass_by")
  deliveryPinVerifiedBy     DeliveryPinVerification[] @relation("pin_verified_by")
  driverDeliveryReviews     DriverDeliveryReview[]
  driverPayoutsCreatedBy    DriverPayout[]            @relation("payout_created_by")
  driverPayoutsPaidBy       DriverPayout[]            @relation("payout_paid_by")
  employeeProfile           EmployeeProfile?
  inventoryAdjustments      InventoryAdjustment[]
  itemReviewReplies         ItemReview[]              @relation("review_admin_reply")
  itemReviews               ItemReview[]              @relation("review_customer")
  orderChangeRequestsBy     OrderChangeRequest[]      @relation("change_requested_by")
  orderChangeResolvedBy     OrderChangeRequest[]      @relation("change_resolved_by")
  orderDriverEventsActor    OrderDriverEvent[]        @relation("driver_event_actor")
  order_eta_events          OrderEtaEvent[]
  orderFinalizationEvents   OrderFinalizationEvent[]  @relation("finalization_confirmed_by")
  orderMessages             OrderMessage[]
  orderPaymentsCreatedBy    OrderPayment[]            @relation("payment_created_by")
  orderPaymentsInitiatedBy  OrderPayment[]            @relation("payment_initiated_by")
  orderStatusEventsActor    OrderStatusEvent[]
  ordersCancelledBy         Order[]                   @relation("cancelled_by")
  ordersAsCustomer          Order[]                   @relation("customer_orders")
  ordersDeliveryCompletedBy Order[]                   @relation("delivery_completed_by")
  ordersStudentVerifiedBy   Order[]                   @relation("student_verified_by")
  promoCodesCreatedBy       PromoCode[]
  promoRedemptions          PromoRedemption[]
  refundApprovedBy          RefundRequest[]           @relation("refund_approved_by")
  refundIssuedBy            RefundRequest[]           @relation("refund_issued_by")
  refundRejectedBy          RefundRequest[]           @relation("refund_rejected_by")
  refundRequestsBy          RefundRequest[]           @relation("refund_requested_by")
  registerSessionsClosed    RegisterSession[]         @relation("register_closed_by")
  registerSessionsOpened    RegisterSession[]         @relation("register_opened_by")
  restockLists              RestockList[]
  savedCarts                SavedCart[]
  supportTicketEvents       SupportTicketEvent[]
  supportTicketMessages     SupportTicketMessage[]
  supportTicketResolutions  SupportTicketResolution[]
  supportTicketsAssigned    SupportTicket[]           @relation("ticket_assigned")
  supportTicketsCustomer    SupportTicket[]           @relation("ticket_customer")
  supportTicketsResolved    SupportTicket[]           @relation("ticket_resolved")
  identities                UserIdentity[]

  @@index([role, isActive], map: "idx_users_role_active")
  @@map("users")
}

model UserIdentity {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  provider        IdentityProvider
  providerSubject String?          @map("provider_subject")
  emailNormalized String?          @unique(map: "uq_email") @map("email_normalized") @db.Citext
  phoneE164       String?          @unique(map: "uq_phone") @map("phone_e164")
  isPrimary       Boolean          @default(false) @map("is_primary")
  isVerified      Boolean          @default(false) @map("is_verified")
  verifiedAt      DateTime?        @map("verified_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  otpCodes        AuthOtpCode[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, providerSubject], map: "uq_provider_subject")
  @@index([userId, isPrimary(sort: Desc)], map: "idx_user_identities_user_primary")
  @@map("user_identities")
}

model AuthOtpCode {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userIdentityId String       @map("user_identity_id") @db.Uuid
  otpHash        String       @map("otp_hash")
  purpose        String
  expiresAt      DateTime     @map("expires_at") @db.Timestamptz(6)
  consumedAt     DateTime?    @map("consumed_at") @db.Timestamptz(6)
  attemptCount   Int          @default(0) @map("attempt_count")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  userIdentity   UserIdentity @relation(fields: [userIdentityId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userIdentityId, purpose, expiresAt], map: "idx_auth_otp_identity_purpose")
  @@map("auth_otp_codes")
}

model CustomerProfile {
  userId                String   @id @map("user_id") @db.Uuid
  marketingOptIn        Boolean  @default(false) @map("marketing_opt_in")
  totalSuccessfulOrders Int      @default(0) @map("total_successful_orders")
  totalNoShows          Int      @default(0) @map("total_no_shows")
  prepaymentRequired    Boolean  @default(false) @map("prepayment_required")
  preferredName         String?  @map("preferred_name")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([prepaymentRequired], map: "idx_customer_profiles_prepayment")
  @@map("customer_profiles")
}

model CustomerAddress {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  label      String?
  line1      String
  city       String
  postalCode String   @map("postal_code")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, updatedAt(sort: Desc)], map: "idx_customer_addresses_user_updated")
  @@map("customer_addresses")
}

model EmployeeProfile {
  userId               String          @id @map("user_id") @db.Uuid
  locationId           String          @map("location_id") @db.Uuid
  role                 EmployeeRole
  employeePinHash      String?         @map("employee_pin_hash")
  hourlyRateCents      Int?            @map("hourly_rate_cents")
  hireDate             DateTime?       @map("hire_date") @db.Date
  isActiveEmployee     Boolean         @default(true) @map("is_active_employee")
  posFailedAttempts    Int             @default(0) @map("pos_failed_attempts")
  posLockoutUntil      DateTime?       @map("pos_lockout_until") @db.Timestamptz(6)
  posCodeDeactivatedAt DateTime?       @map("pos_code_deactivated_at") @db.Timestamptz(6)
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt           DateTime?       @map("archived_at") @db.Timestamptz(6)
  driverProfile        DriverProfile?
  location             Location        @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employeeShifts       EmployeeShift[]

  @@index([locationId, role, isActiveEmployee], map: "idx_employee_profiles_loc_role")
  @@map("employee_profiles")
}

model AdminLocationAssignment {
  userId     String   @map("user_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  isPrimary  Boolean  @default(true) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, locationId])
  @@index([locationId, userId], map: "idx_admin_location_assignments_location")
  @@map("admin_location_assignments")
}

model DriverProfile {
  userId                   String                   @id @map("user_id") @db.Uuid
  locationId               String                   @map("location_id") @db.Uuid
  phoneNumberMirror        String                   @map("phone_number_mirror")
  emailMirror              String?                  @map("email_mirror") @db.Citext
  vehicleType              String?                  @map("vehicle_type")
  vehicleIdentifier        String?                  @map("vehicle_identifier")
  availabilityStatus       DriverAvailabilityStatus @default(OFF_SHIFT) @map("availability_status")
  isActive                 Boolean                  @default(true) @map("is_active")
  isOnDelivery             Boolean                  @default(false) @map("is_on_delivery")
  lastAssignedAt           DateTime?                @map("last_assigned_at") @db.Timestamptz(6)
  lastDeliveryCompletedAt  DateTime?                @map("last_delivery_completed_at") @db.Timestamptz(6)
  totalDeliveriesCompleted Int                      @default(0) @map("total_deliveries_completed")
  averageRatingNumeric     Decimal?                 @map("average_rating_numeric") @db.Decimal(3, 2)
  createdAt                DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt               DateTime?                @map("archived_at") @db.Timestamptz(6)
  driverDeliveryReviews    DriverDeliveryReview[]
  driverPayoutLinks        DriverPayoutOrderLink[]
  driverPayouts            DriverPayout[]
  location                 Location                 @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employeeProfile          EmployeeProfile          @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)
  orderDriverEvents        OrderDriverEvent[]
  ordersAssigned           Order[]

  @@index([locationId, availabilityStatus, isActive], map: "idx_driver_profiles_loc_avail")
  @@map("driver_profiles")
}

model AuthSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceInfo       String?   @map("device_info")
  ipAddress        String?   @map("ip_address") @db.Inet
  locationId       String?   @map("location_id") @db.Uuid
  isPosSession     Boolean   @default(false) @map("is_pos_session")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastActiveAt     DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(6)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedByUserId  String?   @map("revoked_by_user_id") @db.Uuid
  location         Location? @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revokedBy        User?     @relation("session_revoked_by", fields: [revokedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, revokedAt, expiresAt], map: "idx_auth_sessions_user_active")
  @@map("auth_sessions")
}

model LocationSettings {
  locationId                   String   @id @map("location_id") @db.Uuid
  taxRateBps                   Int      @map("tax_rate_bps")
  taxDeliveryFee               Boolean  @default(true) @map("tax_delivery_fee")
  taxTip                       Boolean  @default(false) @map("tax_tip")
  discountsReduceTaxableBase   Boolean  @default(true) @map("discounts_reduce_taxable_base")
  deliveryFeeCents             Int      @default(499) @map("delivery_fee_cents")
  freeDeliveryThresholdCents   Int?     @map("free_delivery_threshold_cents")
  minimumDeliverySubtotalCents Int      @default(0) @map("minimum_delivery_subtotal_cents")
  defaultPrepTimeMinutes       Int      @default(30) @map("default_prep_time_minutes")
  busyModeEnabled              Boolean  @default(false) @map("busy_mode_enabled")
  busyModePrepTimeMinutes      Int?     @map("busy_mode_prep_time_minutes")
  firstOrderDiscountEnabled    Boolean  @default(true) @map("first_order_discount_enabled")
  defaultPromoStackable        Boolean  @default(false) @map("default_promo_stackable")
  prepaymentThresholdNoShows   Int      @default(3) @map("prepayment_threshold_no_shows")
  allowedPostalCodes           Json     @default("[]") @map("allowed_postal_codes")
  trustedIpRanges              Json     @default("[]") @map("trusted_ip_ranges")
  paymentGatewayConfig         Json     @default("{}") @map("payment_gateway_config")
  kdsAutoAcceptSeconds         Int      @default(10) @map("kds_auto_accept_seconds")
  deliveryPinExpiryMinutes     Int      @default(240) @map("delivery_pin_expiry_minutes")
  managerCreditLimitCents      Int?     @map("manager_credit_limit_cents")
  defaultPickupMinMinutes      Int      @default(30) @map("default_pickup_min_minutes")
  defaultPickupMaxMinutes      Int      @default(40) @map("default_pickup_max_minutes")
  defaultDeliveryMinMinutes    Int      @default(40) @map("default_delivery_min_minutes")
  defaultDeliveryMaxMinutes    Int      @default(60) @map("default_delivery_max_minutes")
  overdueDeliveryGraceMinutes  Int      @default(10) @map("overdue_delivery_grace_minutes")
  addItemsAutoApproveEnabled   Boolean  @default(false) @map("add_items_auto_approve_enabled")
  kdsPasswordHash              String?  @map("kds_password_hash") @db.VarChar(255)
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  location                     Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("location_settings")
}

model LocationHours {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId  String   @map("location_id") @db.Uuid
  serviceType String   @map("service_type")
  dayOfWeek   Int      @map("day_of_week") @db.SmallInt
  timeFrom    DateTime @map("time_from") @db.Time(6)
  timeTo      DateTime @map("time_to") @db.Time(6)
  isClosed    Boolean  @default(false) @map("is_closed")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([locationId, serviceType, dayOfWeek, timeFrom, timeTo])
  @@index([locationId, serviceType, dayOfWeek], map: "idx_location_hours_lookup")
  @@map("location_hours")
}

model MenuCategory {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId           String                    @map("location_id") @db.Uuid
  name                 String
  slug                 String
  sortOrder            Int                       @default(0) @map("sort_order")
  isActive             Boolean                   @default(true) @map("is_active")
  archivedAt           DateTime?                 @map("archived_at") @db.Timestamptz(6)
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  location             Location                  @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  menuItems            MenuItem[]
  bxgyQualifyCategory  PromoBxgyRule[]           @relation("bxgy_qualifying_category")
  bxgyRewardCategory   PromoBxgyRule[]           @relation("bxgy_reward_category")
  promoCategoryTargets PromoCodeCategoryTarget[]

  @@unique([locationId, slug])
  @@index([locationId, sortOrder], map: "idx_menu_categories_loc_order")
  @@map("menu_categories")
}

model WingFlavour {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId        String             @map("location_id") @db.Uuid
  name              String
  slug              String
  heatLevel         String             @map("heat_level")
  isPlain           Boolean            @default(false) @map("is_plain")
  isActive          Boolean            @default(true) @map("is_active")
  sortOrder         Int                @default(0) @map("sort_order")
  archivedAt        DateTime?          @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  modifierOptions   ModifierOption[]
  orderItemFlavours OrderItemFlavour[]
  location          Location           @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([locationId, slug])
  @@index([locationId, heatLevel, sortOrder], map: "idx_wing_flavours_loc_heat")
  @@map("wing_flavours")
}

model MenuItem {
  id                          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId                  String                   @map("location_id") @db.Uuid
  categoryId                  String                   @map("category_id") @db.Uuid
  name                        String
  slug                        String
  description                 String?
  basePriceCents              Int                      @map("base_price_cents")
  imageUrl                    String?                  @map("image_url")
  isAvailable                 Boolean                  @default(true) @map("is_available")
  stockStatus                 String                   @default("NORMAL") @map("stock_status")
  isHidden                    Boolean                  @default(false) @map("is_hidden")
  isPopular                   Boolean                  @default(false) @map("is_popular")
  allowedFulfillmentType      String                   @default("BOTH") @map("allowed_fulfillment_type")
  builderType                 String?                  @map("builder_type")
  requiresSpecialInstructions Boolean                  @default(false) @map("requires_special_instructions")
  archivedAt                  DateTime?                @map("archived_at") @db.Timestamptz(6)
  createdAt                   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  modifierGroups              MenuItemModifierGroup[]
  removableIngredients        RemovableIngredient[]
  schedules                   MenuItemSchedule[]
  category                    MenuCategory             @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location                    Location                 @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderItems                  OrderItem[]
  savedCartItems              SavedCartItem[]
  bxgyQualifyProduct          PromoBxgyRule[]          @relation("bxgy_qualifying_product")
  bxgyRewardProduct           PromoBxgyRule[]          @relation("bxgy_reward_product")
  promoProductTargets         PromoCodeProductTarget[]

  @@unique([locationId, slug])
  @@index([locationId, categoryId, isAvailable], map: "idx_menu_items_loc_category")
  @@map("menu_items")
}

model RemovableIngredient {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuItemId String   @map("menu_item_id") @db.Uuid
  name       String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([menuItemId, sortOrder], map: "idx_removable_ingredients_item")
  @@map("removable_ingredients")
}

model ModifierGroup {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId         String                  @map("location_id") @db.Uuid
  name               String
  displayLabel       String                  @map("display_label")
  selectionMode      String                  @map("selection_mode")
  minSelect          Int                     @default(0) @map("min_select")
  maxSelect          Int?                    @map("max_select")
  isRequired         Boolean                 @default(false) @map("is_required")
  sortOrder          Int                     @default(0) @map("sort_order")
  contextKey         String?                 @map("context_key")
  archivedAt         DateTime?               @map("archived_at") @db.Timestamptz(6)
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  menuItems          MenuItemModifierGroup[]
  location           Location                @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  options            ModifierOption[]
  orderItemModifiers OrderItemModifier[]

  @@index([locationId, sortOrder], map: "idx_modifier_groups_loc")
  @@map("modifier_groups")
}

model ModifierOption {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modifierGroupId      String              @map("modifier_group_id") @db.Uuid
  name                 String
  priceDeltaCents      Int                 @default(0) @map("price_delta_cents")
  isDefault            Boolean             @default(false) @map("is_default")
