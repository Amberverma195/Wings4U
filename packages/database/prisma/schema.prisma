/// Per-customer stamp rewards summary.
///
/// Customers earn ONE stamp per whole pound of wings on every order
/// that completes successfully (`status` -> `DELIVERED` or `PICKED_UP`).
/// Every 8 stamps can be redeemed for "1lb of wings free" at checkout.
/// `availableStamps` is capped at 8 by application logic so stampings
/// beyond a full redemption target are ignored until the user redeems.
model CustomerWingsRewards {
  customerUserId   String   @id @map("customer_user_id") @db.Uuid
  /// Current redeemable stamp balance. Capped at 8 — extra pounds don't
  /// accrue until the user redeems the free-wings reward.
  availableStamps  Int      @default(0) @map("available_stamps")
  /// Monotonic lifetime count of stamps ever awarded. Never decreases
  /// on redemption — used only for UI ("X stamps earned to date").
  lifetimeStamps   Int      @default(0) @map("lifetime_stamps")
  /// Monotonic lifetime count of free-wings rewards redeemed. Used
  /// for UI ("X free pounds unlocked").
  lifetimeRedemptions Int   @default(0) @map("lifetime_redemptions")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User     @relation(fields: [customerUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("customer_wings_rewards")
}

/// Audit log of every wings-stamp balance change. Mirrors the
/// `customer_credit_ledger` pattern so revenue/ops tooling can read it
/// the same way. Earn entries reference the `Order` that granted them;
/// redeem entries reference the `Order` the reward was applied to.
model CustomerWingsStampLedger {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerUserId     String   @map("customer_user_id") @db.Uuid
  orderId            String?  @map("order_id") @db.Uuid
  /// `EARNED` (positive delta) or `REDEEMED` (negative delta).
  entryType          String   @map("entry_type")
  /// Signed stamp change — +1..+8 for earn (floored pounds of wings on
  /// the awarding order) or -8 for a single redemption.
  deltaStamps        Int      @map("delta_stamps")
  /// Available-stamp balance after applying `deltaStamps`. Useful for
  /// quickly rendering timelines without a running sum.
  balanceAfterStamps Int      @map("balance_after_stamps")
  /// Pounds of wings on the awarding order (decimal to match
  /// `order_item_wing_configs.weight_lb`). Null on redemption rows.
  poundsAwarded      Decimal? @map("pounds_awarded") @db.Decimal(5, 2)
  reasonText         String   @map("reason_text")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  customer           User     @relation(fields: [customerUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order              Order?   @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([orderId, entryType], map: "uq_customer_wings_stamp_ledger_order_entry_type")
  @@index([customerUserId, createdAt(sort: Desc)], map: "idx_customer_wings_stamps_customer")
  @@map("customer_wings_stamp_ledger")
}

