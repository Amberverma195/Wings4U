model KdsHeartbeat {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  sessionKey String   @map("session_key")
  deviceId   String?  @map("device_id") @db.Uuid
  lastSeenAt DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([locationId, sessionKey], map: "uq_kds_heartbeats_loc_session")
  @@index([locationId, lastSeenAt], map: "idx_kds_heartbeats_loc_last_seen")
  @@map("kds_heartbeats")
}

model BusyModeEvent {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId          String    @map("location_id") @db.Uuid
  startedAt           DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt             DateTime? @map("ended_at") @db.Timestamptz(6)
  startedByUserId     String?   @map("started_by_user_id") @db.Uuid
  endedByUserId       String?   @map("ended_by_user_id") @db.Uuid
  prepMinutesSnapshot Int?      @map("prep_minutes_snapshot")
  note                String?
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  location            Location  @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  startedBy           User?     @relation("busy_event_started_by", fields: [startedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  endedBy             User?     @relation("busy_event_ended_by", fields: [endedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([locationId, startedAt], map: "idx_busy_mode_events_loc_started")
  @@map("busy_mode_events")
}

model PosLoginAttempt {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId        String   @map("location_id") @db.Uuid
  clientIp          String   @map("client_ip")
  deviceFingerprint String?  @map("device_fingerprint")
  wasSuccessful     Boolean  @default(false) @map("was_successful")
  attemptedAt       DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([locationId, clientIp, deviceFingerprint, attemptedAt], map: "idx_pos_login_attempts_lookup")
  @@map("pos_login_attempts")
}

model KdsStationSession {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId String    @map("location_id") @db.Uuid
  sessionKey String    @unique @map("session_key")
  tokenHash  String    @map("token_hash")
  clientIp   String    @map("client_ip") @db.Inet
  deviceId   String?   @map("device_id")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([locationId], map: "idx_kds_station_sessions_loc_active")
  @@index([sessionKey], map: "idx_kds_station_sessions_key")
  @@map("kds_station_sessions")
}

