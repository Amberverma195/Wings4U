# Copy to .env for API/database development.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wings4u
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/wings4u
REDIS_URL=redis://localhost:6379
CATALOG_MENU_CACHE_TTL_SECONDS=60
CATALOG_WING_FLAVOURS_CACHE_TTL_SECONDS=300
JWT_SECRET=dev-secret-change-me
STORE_TIMEZONE=America/Toronto

# OTP delivery (email via Resend).
#   OTP_PROVIDER=console  -> logs codes to the server console (local dev)
#   OTP_PROVIDER=resend   -> emails codes via Resend (also auto-selected when RESEND_API_KEY is set)
OTP_PROVIDER=console
RESEND_API_KEY=your-resend-api-key
# Sender on your verified Resend domain (display name + address).
RESEND_FROM=Wings 4 U <no-reply@wings4ulondon.ca>

# Stripe online card payments. Replace placeholders with your Stripe test/live keys.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_CURRENCY=cad
STRIPE_MERCHANT_DISPLAY_NAME=Wings4U
