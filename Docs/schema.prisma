  name            String
  status          String   // OPEN, ORDERED, COMPLETED, ARCHIVED
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  location  Location          @relation(fields: [locationId], references: [id])
  createdBy User              @relation(fields: [createdByUserId], references: [id])
  items     RestockListItem[]

  @@index([locationId, status], map: "idx_restock_lists_loc_status")
  @@map("restock_lists")
}

model RestockListItem {
  id                       String   @id @default(uuid()) @db.Uuid
  restockListId            String   @map("restock_list_id") @db.Uuid
  inventoryItemId          String   @map("inventory_item_id") @db.Uuid
  requestedQuantityNumeric Decimal  @map("requested_quantity_numeric") @db.Decimal(12, 2)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz

  restockList   RestockList   @relation(fields: [restockListId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([restockListId], map: "idx_restock_list_items_list")
  @@map("restock_list_items")
}

model Device {
  id                String    @id @default(uuid()) @db.Uuid
  locationId        String    @map("location_id") @db.Uuid
  deviceType        String    @map("device_type") // KDS_SCREEN, POS_TERMINAL, RECEIPT_PRINTER, CASH_DRAWER, TIMECLOCK_TERMINAL
  name              String
  stationKey        String?   @map("station_key")
  ipAddress         String?   @map("ip_address") @db.Inet
  isActive          Boolean   @default(true) @map("is_active")
  lastSeenAt        DateTime? @map("last_seen_at") @db.Timestamptz
  metadataJson      Json      @default("{}") @map("metadata_json")
  apiTokenHash      String?   @map("api_token_hash")
  deviceRegisteredAt DateTime? @map("device_registered_at") @db.Timestamptz
  tokenLastUsedAt   DateTime? @map("token_last_used_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  location       Location         @relation(fields: [locationId], references: [id])
  registers      Register[]
  employeeShifts EmployeeShift[]

  @@index([locationId, deviceType], map: "idx_devices_loc_type")
  @@map("devices")
}

model Register {
  id         String   @id @default(uuid()) @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  deviceId   String?  @map("device_id") @db.Uuid
  name       String
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  location Location          @relation(fields: [locationId], references: [id])
  device   Device?           @relation(fields: [deviceId], references: [id])
  sessions RegisterSession[]

  @@unique([locationId, name])
  @@index([locationId, isActive], map: "idx_registers_loc_active")
  @@map("registers")
}

model RegisterSession {
  id                String    @id @default(uuid()) @db.Uuid
  registerId        String    @map("register_id") @db.Uuid
  locationId        String    @map("location_id") @db.Uuid
  openedByUserId    String    @map("opened_by_user_id") @db.Uuid
  closedByUserId    String?   @map("closed_by_user_id") @db.Uuid
  openingFloatCents Int       @map("opening_float_cents")
  expectedCloseCents Int?     @map("expected_close_cents")
  actualCloseCents   Int?     @map("actual_close_cents")
  openedAt          DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  closedAt          DateTime? @map("closed_at") @db.Timestamptz
  status            String    // OPEN, CLOSED

  register   Register           @relation(fields: [registerId], references: [id])
  location   Location           @relation(fields: [locationId], references: [id])
  openedBy   User               @relation("register_opened_by", fields: [openedByUserId], references: [id])
  closedBy   User?              @relation("register_closed_by", fields: [closedByUserId], references: [id])
  drawerEvents CashDrawerEvent[]

  @@index([registerId, status], map: "idx_register_sessions_register_status")
  @@map("register_sessions")
}

model CashDrawerEvent {
  id                String   @id @default(uuid()) @db.Uuid
  registerSessionId String   @map("register_session_id") @db.Uuid
  eventType         String   @map("event_type") // SALE_CASH_IN, CHANGE_GIVEN, NO_SALE, SAFE_DROP, ADJUSTMENT
  amountCents       Int      @default(0) @map("amount_cents")
  actorUserId       String   @map("actor_user_id") @db.Uuid
  approvedByUserId  String?  @map("approved_by_user_id") @db.Uuid
  reasonText        String?  @map("reason_text")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  registerSession RegisterSession @relation(fields: [registerSessionId], references: [id], onDelete: Cascade)
  actor           User            @relation("drawer_actor", fields: [actorUserId], references: [id])
  approvedBy      User?           @relation("drawer_approved_by", fields: [approvedByUserId], references: [id])

  @@index([registerSessionId, createdAt], map: "idx_cash_drawer_events_session_created")
  @@map("cash_drawer_events")
}

model EmployeeShift {
  id                String    @id @default(uuid()) @db.Uuid
  employeeUserId    String    @map("employee_user_id") @db.Uuid
  locationId        String    @map("location_id") @db.Uuid
  deviceId          String?   @map("device_id") @db.Uuid
  clockInAt         DateTime  @default(now()) @map("clock_in_at") @db.Timestamptz
  clockOutAt        DateTime? @map("clock_out_at") @db.Timestamptz
  status            String    // CLOCKED_IN, ON_BREAK, CLOCKED_OUT
  totalBreakMinutes Int       @default(0) @map("total_break_minutes")
  netWorkedMinutes  Int?      @map("net_worked_minutes")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee EmployeeProfile @relation(fields: [employeeUserId], references: [userId])
  location Location        @relation(fields: [locationId], references: [id])
  device   Device?         @relation(fields: [deviceId], references: [id])
  breaks   EmployeeBreak[]

  @@index([employeeUserId, status, clockInAt(sort: Desc)], map: "idx_employee_shifts_emp_open")
  @@index([locationId, status], map: "idx_employee_shifts_loc_open")
  @@map("employee_shifts")
}

model EmployeeBreak {
  id              String    @id @default(uuid()) @db.Uuid
  employeeShiftId String    @map("employee_shift_id") @db.Uuid
  breakType       String    @map("break_type") // UNPAID
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt         DateTime? @map("ended_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  shift EmployeeShift @relation(fields: [employeeShiftId], references: [id], onDelete: Cascade)

  @@index([employeeShiftId, startedAt], map: "idx_employee_breaks_shift")
  @@map("employee_breaks")
}

// ============================================================================
// CATERING & AUDIT
// ============================================================================

model CateringInquiry {
  id                 String    @id @default(uuid()) @db.Uuid
  customerUserId     String?   @map("customer_user_id") @db.Uuid
  name               String
  email              String    @db.Citext
  phoneNumber        String    @map("phone_number")
  eventDate          DateTime? @map("event_date") @db.Date
  messageBody        String    @map("message_body")
  status             String    @default("NEW") // NEW, CONTACTED, WON, LOST, ARCHIVED
  assignedLocationId String?   @map("assigned_location_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  customer         User?     @relation(fields: [customerUserId], references: [id])
  assignedLocation Location? @relation(fields: [assignedLocationId], references: [id])

  @@index([status, createdAt(sort: Desc)], map: "idx_catering_inquiries_status")
  @@map("catering_inquiries")
}

model AdminAuditLog {
  id               String   @id @default(uuid()) @db.Uuid
  locationId       String?  @map("location_id") @db.Uuid
  actorUserId      String?  @map("actor_user_id") @db.Uuid
  actorRoleSnapshot String  @map("actor_role_snapshot")
  actionKey        String   @map("action_key")
  entityType       String   @map("entity_type")
  entityId         String?  @map("entity_id") @db.Uuid
  reasonText       String?  @map("reason_text")
  payloadJson      Json     @default("{}") @map("payload_json")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  location Location? @relation(fields: [locationId], references: [id])
  actor    User?     @relation(fields: [actorUserId], references: [id])

  @@index([locationId, createdAt(sort: Desc)], map: "idx_admin_audit_logs_loc_created")
  @@index([actorUserId, createdAt(sort: Desc)], map: "idx_admin_audit_logs_actor_created")
  @@index([entityType, entityId], map: "idx_admin_audit_logs_entity")
  @@map("admin_audit_logs")
}

// ============================================================================
// REPORTING
// ============================================================================

model DailyTaxSummary {
  businessDate           DateTime @map("business_date") @db.Date
  locationId             String   @map("location_id") @db.Uuid
  ordersCount            Int      @default(0) @map("orders_count")
  taxableSalesCents      Int      @default(0) @map("taxable_sales_cents")
  taxCollectedCents      Int      @default(0) @map("tax_collected_cents")
  refundTaxReversedCents Int      @default(0) @map("refund_tax_reversed_cents")
  netTaxCents            Int      @default(0) @map("net_tax_cents")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  location Location @relation(fields: [locationId], references: [id])

  @@id([businessDate, locationId])
  @@index([locationId, businessDate(sort: Desc)], map: "idx_daily_tax_summary_loc")
  @@map("daily_tax_summary")
}
