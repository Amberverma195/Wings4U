}

model SupportTicket {
  id                  String                @id @default(uuid()) @db.Uuid
  locationId          String                @map("location_id") @db.Uuid
  orderId             String?               @map("order_id") @db.Uuid
  customerUserId      String?               @map("customer_user_id") @db.Uuid
  ticketType          String                @map("ticket_type")
  status              TicketStatus
  resolutionType      TicketResolutionType? @map("resolution_type")
  subject             String
  description         String
  createdSource       String                @map("created_source") // CUSTOMER | CUSTOMER_APP | STAFF | STAFF_PANEL | ADMIN_PANEL | AUTO_OVERDUE
  priority            String                @default("NORMAL")
  assignedAdminUserId String?               @map("assigned_admin_user_id") @db.Uuid
  resolvedByUserId    String?               @map("resolved_by_user_id") @db.Uuid
  resolvedAt          DateTime?             @map("resolved_at") @db.Timestamptz
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  location       Location                  @relation(fields: [locationId], references: [id])
  order          Order?                    @relation(fields: [orderId], references: [id])
  customer       User?                     @relation("ticket_customer", fields: [customerUserId], references: [id])
  assignedAdmin  User?                     @relation("ticket_assigned", fields: [assignedAdminUserId], references: [id])
  resolvedBy     User?                     @relation("ticket_resolved", fields: [resolvedByUserId], references: [id])
  refundRequests RefundRequest[]
  messages       SupportTicketMessage[]
  resolutions    SupportTicketResolution[]
  events         SupportTicketEvent[]

  @@index([locationId, status, createdAt(sort: Desc)], map: "idx_support_tickets_loc_status")
  @@index([orderId], map: "idx_support_tickets_order")
  @@map("support_tickets")
}

model RefundRequest {
  id                String       @id @default(uuid()) @db.Uuid
  orderId           String       @map("order_id") @db.Uuid
  locationId        String       @map("location_id") @db.Uuid
  supportTicketId   String?      @map("support_ticket_id") @db.Uuid
  requestedByUserId String       @map("requested_by_user_id") @db.Uuid
  amountCents       Int          @map("amount_cents")
  refundMethod      RefundMethod @default(STORE_CREDIT) @map("refund_method")
  status            RefundStatus @default(PENDING)
  reasonText        String       @map("reason_text")
  approvedByUserId  String?      @map("approved_by_user_id") @db.Uuid
  approvedAt        DateTime?    @map("approved_at") @db.Timestamptz
  issuedByUserId    String?      @map("issued_by_user_id") @db.Uuid
  issuedAt          DateTime?    @map("issued_at") @db.Timestamptz
  rejectedByUserId  String?      @map("rejected_by_user_id") @db.Uuid
  rejectedAt        DateTime?    @map("rejected_at") @db.Timestamptz
  processorReference String?     @map("processor_reference")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  location        Location       @relation(fields: [locationId], references: [id])
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id])
