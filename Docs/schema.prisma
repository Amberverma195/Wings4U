model OrderPayment {
  id                    String                   @id @default(uuid()) @db.Uuid
  orderId               String                   @map("order_id") @db.Uuid
  locationId            String                   @map("location_id") @db.Uuid
  paymentMethod         PaymentTenderMethod      @map("payment_method")
  transactionType       PaymentTransactionType   @default(CAPTURE) @map("transaction_type")
  transactionStatus     PaymentTransactionStatus @default(PENDING) @map("transaction_status")
  signedAmountCents     Int                      @map("signed_amount_cents")
