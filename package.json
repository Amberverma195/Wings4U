{
  "name": "wings4u-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace @wings4u/web",
    "dev:api": "npm run dev --workspace @wings4u/api",
    "dev:print-agent": "npm run dev --workspace @wings4u/print-agent",
    "build:web": "npm run build --workspace @wings4u/web",
    "build:api": "npm run build --workspace @wings4u/api",
    "build:pricing": "npm run build --workspace @wings4u/pricing",
    "build:contracts": "npm run build --workspace @wings4u/contracts",
    "build:database": "npm run build --workspace @wings4u/database",
    "db:pull": "npm run prisma:pull --workspace @wings4u/database",
    "db:validate": "npm run prisma:validate --workspace @wings4u/database",
    "db:generate": "npm run prisma:generate --workspace @wings4u/database",
    "db:migrate": "npm run prisma:migrate --workspace @wings4u/database",
    "db:deploy": "npm run prisma:deploy --workspace @wings4u/database",
    "db:builder:sync": "tsx packages/database/prisma/sync-builder-config.ts --location-code LON01",
    "db:menu:extract": "tsx packages/database/prisma/extract-menu-docx.ts \"Docs/This menu for Wings 4 U contains a wide variety of wings.docx\" --out \"Docs/menu/wings4u-menu.v1.json\"",
    "db:menu:import": "tsx packages/database/prisma/import-menu.ts --json \"Docs/menu/wings4u-menu.v1.json\" --location-code LON01",
    "test:e2e": "npm run test:e2e --workspace @wings4u/api",
    "ci": "npm run db:generate && npm run build:database && npm run build:api && npm run build:web && npm run test:e2e"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
