# Copy to apps/print-agent/.env before running `npm run dev:print-agent`.
# The agent will not connect to realtime unless the required vars are set.

# Base URL of the Nest API. It must terminate WebSocket upgrades for /ws.
PRINT_AGENT_API_ORIGIN=http://localhost:3001

# Location id this print agent prints for.
PRINT_AGENT_LOCATION_ID=00000000-0000-4000-8000-000000000000

# 8-digit KDS station password configured in Admin Store Settings.
PRINT_AGENT_KDS_PASSWORD=12345678
