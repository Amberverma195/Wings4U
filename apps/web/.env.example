# Browser: Socket.IO connects to API (not through Next rewrites)
NEXT_PUBLIC_REALTIME_ORIGIN=http://127.0.0.1:3001

# Default location for menu/cart. Must match `locations.id` for LON01 (or your store) in the DB.
# Restart Next after changing any NEXT_PUBLIC_* value.
NEXT_PUBLIC_DEFAULT_LOCATION_ID=00000000-0000-4000-8000-000000000000

# Server-side fetch from Next RSC (if used)
INTERNAL_API_URL=http://127.0.0.1:3001

# Optional (local dev): browser calls Nest directly — skips Next `/api` rewrites. Fixes plain-text 500
# from the dev proxy when the API is actually running on 3001. Omit in production.
# NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:3001

# Optional: where Next proxies /api/* (see next.config.ts)
# API_PROXY_TARGET=http://localhost:3001

# Required for server-side / middleware route protection (admin gating).
# Must match the API's JWT_SECRET so the access_token cookie signed by Nest
# can be verified by Next middleware and server components. Never expose this
# with a NEXT_PUBLIC_* prefix — it must stay server-only.
JWT_SECRET=dev-secret-change-me
