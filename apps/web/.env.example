# Copy to apps/web/.env.local for local web development.
#
# REST calls can use Next rewrites, but Socket.IO `/ws` must connect to
# the Nest API directly unless a production reverse proxy handles WebSocket
# upgrades.

# Direct origin of the Nest API for browser REST and Socket.IO (local dev).
# In production the browser intentionally uses same-origin `/api/*`
# rewrites instead; see `API_PROXY_TARGET` so auth cookies stay on your
# site domain. Set this only for local dev unless you opt out with
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=0.
NEXT_PUBLIC_API_ORIGIN=http://localhost:3001

# Optional: explicit realtime gateway origin if it differs from the API.
# NEXT_PUBLIC_REALTIME_ORIGIN=http://localhost:3001

# Default location for menu/cart/KDS. Must match a real locations.id.
NEXT_PUBLIC_DEFAULT_LOCATION_ID=00000000-0000-4000-8000-000000000000

# Server-side fetch from Next RSC/layouts.
INTERNAL_API_URL=http://127.0.0.1:3001

# Required on Vercel: where Next proxies browser `/api/*` requests (your Railway
# Nest API URL, no trailing slash). Without this, production login sets cookies
# on the wrong host and session checks fail after redirect.
# API_PROXY_TARGET=https://your-api.up.railway.app

# Optional: force direct cross-origin API calls in production. This is not
# recommended for auth because third-party cookies break login.
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=0

# Required for server-side / middleware route protection.
JWT_SECRET=dev-secret-change-me
